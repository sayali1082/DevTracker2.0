{
  "entities": {
    "User": {
      "title": "User",
      "description": "Developer profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "skills": { "type": "array" },
        "githubUsername": { "type": "string" },
        "githubStats": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A developer project details",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "techStack": { "type": "array" },
        "githubRepoLink": { "type": "string" },
        "liveDemoLink": { "type": "string" },
        "status": { "type": "string", "enum": ["In Progress", "Completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "userId", "title", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects created by the user"
    }
  }
}
